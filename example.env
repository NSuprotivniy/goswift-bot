# Copy this file to .env and fill in the values.

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_OWNER_CHAT_ID=123456789
LOG_LEVEL=INFO
LOGS_MAX_GB=5
LOG_CHUNK_MB=1024

GOSWIFT_BASE_URL=https://www.eestipiir.ee
# Optional. If the site blocks anonymous session bootstrap, paste the full
# Cookie header value from your browser session here.
GOSWIFT_COOKIE=

# Optional location filters. Default is both locations.
GOSWIFT_LOCATIONS=koidula,luhamaa
# Legacy fallback: also accepts koidula/luhamaa or 2/3.
GOSWIFT_CHECKPOINT_ID=
GOSWIFT_DIRECTION=
GOSWIFT_CATEGORY=B

# Check interval in minutes
CHECK_INTERVAL_MINUTES=10

# Date range to scan (YYYY-MM-DD). Both required for range scanning.
# Scans each date with 1–10 second random delay between requests.
GOSWIFT_DATE_FIRST=2026-04-01
GOSWIFT_DATE_LAST=2026-04-10

# For manual deep debugging, switch to DEBUG before starting the bot.
# Warning: debug logs may contain sensitive runtime data and raw payloads.
# LOG_LEVEL=DEBUG
